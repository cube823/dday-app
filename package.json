{
  "name": "dday-app",
  "version": "1.0.0",
  "description": "D-Day Countdown and Learning Tracker",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"npm run server\"",
    "dev:frontend": "vite",
    "dev:backend": "node server/index.js",
    "server": "node server/index.js",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "start": "NODE_ENV=production node server/index.js"
  },
  "keywords": [
    "react",
    "typescript",
    "countdown",
    "web-app"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^4.22.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^20.11.19",
    "@types/react": "^18.2.56",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.3"
  }
}
